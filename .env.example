FIRECRAWL_KEY="YOUR_KEY"
# Docker/self-hosted Firecrawl: set base URL (search + scrape use this for richer content)
# FIRECRAWL_BASE_URL="http://localhost:3002"
# Optional: SEARCH_CONCURRENCY (default 4 when Firecrawl used), USE_FIRECRAWL_SCRAPE=false to disable scrape

OPENAI_KEY="YOUR_KEY"
CONTEXT_SIZE="128000"

# If you want to use other OpenAI compatible API, add the following below:
# OPENAI_ENDPOINT="http://localhost:11434/v1"
# CUSTOM_MODEL="llama3.1"

# If you want to use fireworks.ai's DeepSeek R1 model:
# FIREWORKS_KEY="YOUR_KEY"
